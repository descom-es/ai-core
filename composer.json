{
    "name": "descom/ai-core",
    "description": "A Laravel module for AI core functionalities",
    "type": "library",
    "keywords": ["laravel", "module", "ai-core", "aws-bedrock", "tools"],
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Descom\\Ai\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Descom\\Ai\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "aws/aws-sdk-php": "^3.300",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^12.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Descom\\Ai\\AiServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
